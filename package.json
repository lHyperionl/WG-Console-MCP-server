{
    "name": "wargaming-mcp-server",
    "version": "2.2.0",
    "description": "MCP server for the Wargaming World of Tanks Console API: player stats, session/progress tracking, player & tank comparisons, clan reports, and the full Tankopedia",
    "type": "module",
    "main": "./build/index.js",
    "bin": {
        "wargaming-mcp-server": "build/index.js"
    },
    "scripts": {
        "build": "tsc",
        "start": "node build/index.js",
        "dev": "tsc && node build/index.js",
        "test": "tsc && node test/smoke-test.js",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "mcp",
        "modelcontextprotocol",
        "mcp-server",
        "wargaming",
        "world-of-tanks",
        "world-of-tanks-console",
        "console",
        "api"
    ],
    "author": "Dávid Tkáč",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/lHyperionl/WG-Console-MCP-server.git"
    },
    "homepage": "https://github.com/lHyperionl/WG-Console-MCP-server#readme",
    "bugs": {
        "url": "https://github.com/lHyperionl/WG-Console-MCP-server/issues"
    },
    "engines": {
        "node": ">=18"
    },
    "files": [
        "build"
    ],
    "devDependencies": {
        "@types/node": "^24.0.14",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.15.1",
        "dotenv": "^17.2.0",
        "zod": "^3.25.76"
    }
}
