{
    "metadata": {
        "category": "Tankopedia Methods",
        "description": "Game encyclopedia data endpoints for World of Tanks Console API",
        "base_url": "https://api-modernarmor.worldoftanks.com",
        "endpoints_count": 9,
        "note": "These endpoints provide access to game encyclopedia data including vehicles, achievements, maps, modules, and crew information"
    },
    "encyclopedia_vehicles": {
        "endpoint": "/wotx/encyclopedia/vehicles/",
        "url": "https://api-modernarmor.worldoftanks.com/wotx/encyclopedia/vehicles/?application_id=a7734243d7c7bc1450bd07395f3a77e3",
        "description": "Returns list of available vehicles.",
        "parameters": {
            "application_id": {
                "type": "string",
                "required": true,
                "description": "Application ID"
            },
            "fields": {
                "type": "string,list",
                "required": false,
                "description": "Response field. The fields are separated with commas. Embedded fields are separated with dots. To exclude a field, use '-' in front of its name. In case the parameter is not defined, the method returns all fields. Maximum limit: 100."
            },
            "language": {
                "type": "string",
                "required": false,
                "default": "en",
                "description": "Localization language. Valid values: en, ru, pl, de, fr, es, tr."
            },
            "limit": {
                "type": "numeric",
                "required": false,
                "description": "Number of returned entries (fewer can be returned, but not more than 100). If the limit sent exceeds 100, a limit of 100 is applied (by default)."
            },
            "nation": {
                "type": "string,list",
                "required": false,
                "description": "Nation. Maximum limit: 100."
            },
            "page_no": {
                "type": "numeric",
                "required": false,
                "description": "Result page number"
            },
            "tank_id": {
                "type": "numeric,list",
                "required": false,
                "description": "Vehicle ID. Maximum limit: 100."
            },
            "tier": {
                "type": "numeric,list",
                "required": false,
                "description": "Tier. Maximum limit: 100."
            }
        },
        "response": {
            "description": "string",
            "era": "string",
            "has_multi_weapon": "boolean",
            "is_premium": "boolean",
            "name": "string",
            "nation": "string",
            "next_tanks": "associative array",
            "price_credit": "numeric",
            "price_gold": "numeric",
            "prices_xp": "associative array",
            "short_name": "string",
            "tag": "string",
            "tank_id": "numeric",
            "tier": "numeric",
            "total_turrets": "numeric",
            "type": "string",
            "images": {
                "big_icon": "string"
            },
            "modules_tree": {
                "is_default": "boolean",
                "module_id": "numeric",
                "name": "string",
                "next_modules": "list of integers",
                "next_tanks": "list of integers",
                "price_credit": "numeric",
                "price_xp": "numeric",
                "type": "string"
            }
        },
        "errors": "Common API errors"
    },
